{
  "name": "@drunik/godot-mcp",
  "version": "0.2.0",
  "description": "MCP server for Godot game engine integration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drunikbe/godot-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "godot-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "daemon": "tsx src/index.ts --daemon",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "godot",
    "game-development",
    "ai-assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.25.2",
    "express": "^5.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
